# Copy this file to .env and replace every change-me value before starting.

COMPOSE_PROJECT_NAME=personal-infra
TZ=America/Denver

# Shared Docker network used by app repositories.
SHARED_NETWORK_NAME=personal-infra-shared

# Host directory used for persistent app and infra data.
# Defaults to /srv if unset. For local macOS development, use a home directory,
# e.g. HOST_DATA_ROOT=/Users/you/personal-infra-data
HOST_DATA_ROOT=/srv

# Use ./caddy/Caddyfile after copying caddy/Caddyfile.example and adding real domains.
CADDYFILE_PATH=./caddy/Caddyfile.example

# Postgres
POSTGRES_USER=infra_admin
POSTGRES_PASSWORD=change-me-postgres-root-password
POSTGRES_DB=postgres

# MongoDB
MONGO_INITDB_ROOT_USERNAME=infra_admin
MONGO_INITDB_ROOT_PASSWORD=change-me-mongo-root-password

# Redis
REDIS_PASSWORD=change-me-redis-password

# Listen
LISTEN_POSTGRES_PASSWORD=change-me-listen-db-password

# Restic repository settings. Examples:
# RESTIC_REPOSITORY=s3:s3.us-west-004.backblazeb2.com/my-bucket/vultr-personal-infra
# RESTIC_REPOSITORY=sftp:user@example.com:/backups/personal-infra
RESTIC_REPOSITORY=
RESTIC_PASSWORD=change-me-long-random-restic-password

# S3-compatible credentials for Backblaze B2, Cloudflare R2, AWS S3, etc.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
