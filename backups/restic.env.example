# Optional separate Restic env file for systemd or cron jobs.
# If you use docker compose, these values can also live in the repo-level .env.

RESTIC_REPOSITORY=s3:s3.us-west-004.backblazeb2.com/my-bucket/vultr-personal-infra
RESTIC_PASSWORD=change-me-long-random-restic-password

AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_DEFAULT_REGION=auto
