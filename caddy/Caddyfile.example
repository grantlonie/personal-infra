{
	# Add an email here after copying this file to caddy/Caddyfile if you want
	# Let's Encrypt expiration notices.
	# email you@example.com
}

:80 {
	respond "personal-infra Caddy is running"
}

# Example app route. Copy this file to caddy/Caddyfile, then replace the
# hostname and upstream service names as you add app repositories.
#
# monitor.example.com {
# 	reverse_proxy uptime-kuma:3001
# }
#
recipes.grantlonie.com {
	reverse_proxy mealie:9000
}

listen.grantlonie.com {
	reverse_proxy /api/* listen-backend:8000
	reverse_proxy /health listen-backend:8000
	reverse_proxy listen-frontend:80
}
